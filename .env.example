# Backend
PORCHQUEST_DATA_DIR=../../data

# DM mode
# local = deterministic fallback DM only
# openai_compat = call a server-side OpenAI-compatible /v1/chat/completions endpoint
PORCHQUEST_DM_BACKEND=local
PORCHQUEST_DM_TEMPERATURE=0.7
PORCHQUEST_OPENAI_COMPAT_BASE_URL=http://127.0.0.1:11434
PORCHQUEST_OPENAI_COMPAT_MODEL=llama3.2
# Keep this server-side only. Never place model/API keys in the public GitHub Pages app.
PORCHQUEST_OPENAI_COMPAT_API_KEY=

# Frontend
VITE_API_BASE=http://127.0.0.1:8787
# GitHub Pages workflow sets these automatically for static play:
# VITE_STATIC_PLAY=1
# VITE_BASE_PATH=/PorchQuest369/
